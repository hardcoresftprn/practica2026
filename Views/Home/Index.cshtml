@{
    Layout = null;
    var userName = Context.Session.GetString("UserName") ?? "Alexei";
    var firstName = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "Alexei";
}

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>sdsAUTO - Dashboard</title>
    <style>
        * {
            box-sizing: border-box;
        }

        html,
        body {
            width: 100%;
            height: 100%;
            margin: 0;
            background: #000000;
            color: #F8FAFC;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            overflow: hidden;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .app-container {
            aspect-ratio: 16/9;
            max-width: 100vw;
            max-height: 100vh;
            margin: auto;
            position: relative;
            overflow: hidden;
            background: #0F172A;
        }

        @@media (max-aspect-ratio: 16/9) {
            .app-container {
                width: 100vw;
                height: calc(100vw * 9/16);
            }
        }

        @@media (min-aspect-ratio: 16/9) {
            .app-container {
                height: 100vh;
                width: calc(100vh * 16/9);
            }
        }

        @@media (orientation: portrait) and (max-width: 768px) {
            .app-container::before {
                content: "Rotiți dispozitivul în modul landscape";
                position: fixed;
                inset: 0;
                background: #000;
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 9999;
                font-size: 18px;
                text-align: center;
                padding: 24px;
            }
        }

        @@media (min-height: 720px) {
            .screen {
                --scale-space: 1;
            }
        }

        @@media (max-height: 1080px) {
            .screen {
                --scale-space: 1;
            }
        }

        .screen {
            height: 100%;
            display: grid;
            grid-template-rows: 60px auto 1fr 64px;
            background: #0F172A;
        }

        .header {
            height: 60px;
            background: #0F172A;
            border-bottom: 1px solid #334155;
            display: grid;
            grid-template-columns: 56px 1fr 48px 52px;
            align-items: center;
            padding: 0 16px;
        }

        .hamburger,
        .bell,
        .nav-icon {
            width: 24px;
            height: 24px;
            color: currentColor;
            display: block;
        }

        .hamburger-btn,
        .bell-btn {
            width: 36px;
            height: 36px;
            border: 0;
            background: transparent;
            color: #F8FAFC;
            display: grid;
            place-items: center;
            padding: 0;
        }

        .logo {
            color: #2563EB;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: 0;
        }

        .bell-wrap {
            position: relative;
            justify-self: center;
        }

        .bell-dot {
            position: absolute;
            top: 5px;
            right: 6px;
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: #EF4444;
            border: 1px solid #0F172A;
        }

        .avatar {
            width: 36px;
            height: 36px;
            justify-self: end;
            border-radius: 999px;
            background: linear-gradient(135deg, #2563EB, #1E3A8A);
            border: 2px solid #334155;
            color: #F8FAFC;
            display: grid;
            place-items: center;
            font-size: 12px;
            font-weight: 800;
        }

        .welcome {
            padding: 16px 20px;
        }

        .welcome h1 {
            margin: 0 0 4px;
            color: #F8FAFC;
            font-size: 24px;
            font-weight: 800;
            line-height: 1.15;
        }

        .welcome p {
            margin: 0;
            color: #94A3B8;
            font-size: 14px;
            line-height: 1.35;
        }

        .content {
            min-height: 0;
            overflow: hidden;
            padding-bottom: 8px;
        }

        .fleet-health {
            position: relative;
            margin: 0 16px 12px;
            padding: 20px;
            border-radius: 12px;
            background: #1E293B;
            border: 1px solid rgba(51, 65, 85, 0.65);
        }

        .section-label {
            margin: 0;
            color: #94A3B8;
            font-size: 12px;
            line-height: 1.2;
            font-weight: 800;
            letter-spacing: 0.13em;
            text-transform: uppercase;
        }

        .chart-icon {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 20px;
            height: 20px;
            color: #94A3B8;
        }

        .health-row {
            display: flex;
            align-items: baseline;
            gap: 12px;
            margin-top: 10px;
        }

        .health-value {
            color: #F8FAFC;
            font-size: 48px;
            line-height: 1;
            font-weight: 900;
        }

        .health-delta {
            color: #2563EB;
            font-size: 16px;
            font-weight: 800;
        }

        .progress {
            height: 4px;
            width: 100%;
            margin-top: 14px;
            border-radius: 999px;
            background: #334155;
            overflow: hidden;
        }

        .progress span {
            display: block;
            width: 98%;
            height: 100%;
            border-radius: inherit;
            background: #2563EB;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 0 16px 14px;
        }

        .stat-card {
            min-height: 104px;
            padding: 16px;
            border-radius: 12px;
            background: #1E293B;
            border: 1px solid rgba(51, 65, 85, 0.65);
        }

        .stat-icon {
            width: 20px;
            height: 20px;
            color: #F59E0B;
            margin-bottom: 9px;
        }

        .stat-value {
            color: #F8FAFC;
            font-size: 32px;
            line-height: 1;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .stat-label {
            color: #94A3B8;
            font-size: 10px;
            line-height: 1.2;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }

        .live-map {
            margin: 0 16px 14px;
        }

        .section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .section-title {
            margin: 0;
            color: #F8FAFC;
            font-size: 16px;
            line-height: 1.2;
            font-weight: 800;
        }

        .fleet-badge {
            color: #2563EB;
            border: 1px solid #2563EB;
            border-radius: 4px;
            padding: 4px 12px;
            font-size: 12px;
            line-height: 1;
            font-weight: 800;
            letter-spacing: 0.04em;
        }

        .map-box {
            position: relative;
            height: 180px;
            width: 100%;
            overflow: hidden;
            border-radius: 12px;
            background:
                linear-gradient(30deg, transparent 0 44%, rgba(148, 163, 184, 0.18) 45% 47%, transparent 48% 100%),
                linear-gradient(150deg, transparent 0 36%, rgba(148, 163, 184, 0.16) 37% 39%, transparent 40% 100%),
                radial-gradient(circle at 18% 22%, rgba(37, 99, 235, 0.18), transparent 18%),
                #111827;
            border: 1px solid #334155;
        }

        .map-road {
            position: absolute;
            background: rgba(148, 163, 184, 0.24);
            border-radius: 999px;
            transform-origin: center;
        }

        .road-a {
            width: 140%;
            height: 3px;
            left: -18%;
            top: 42%;
            transform: rotate(-12deg);
        }

        .road-b {
            width: 115%;
            height: 3px;
            left: -8%;
            top: 66%;
            transform: rotate(18deg);
        }

        .road-c {
            width: 72%;
            height: 2px;
            right: -10%;
            top: 22%;
            transform: rotate(36deg);
        }

        .road-d {
            width: 3px;
            height: 150%;
            left: 32%;
            top: -20%;
            transform: rotate(16deg);
        }

        .location {
            position: absolute;
            left: 58%;
            top: 47%;
            width: 12px;
            height: 12px;
            border-radius: 999px;
            background: #2563EB;
            box-shadow: 0 0 16px rgba(37, 99, 235, 0.9);
        }

        .location::before {
            content: "";
            position: absolute;
            inset: -9px;
            border-radius: inherit;
            border: 2px solid #2563EB;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% {
                transform: scale(0.7);
                opacity: 0.95;
            }
            70% {
                transform: scale(1.85);
                opacity: 0;
            }
            100% {
                transform: scale(1.85);
                opacity: 0;
            }
        }

        .recent-title {
            margin: 0;
            padding: 0 16px 10px;
            color: #F8FAFC;
            font-size: 16px;
            line-height: 1.2;
            font-weight: 800;
        }

        .fleet-list {
            max-height: calc(100% - 536px);
            min-height: 176px;
            overflow-y: auto;
            padding: 0 16px 10px;
            scrollbar-width: thin;
            scrollbar-color: #334155 transparent;
        }

        .vehicle-card {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            margin-bottom: 8px;
            border-radius: 12px;
            background: #1E293B;
            border: 1px solid rgba(51, 65, 85, 0.65);
        }

        .vehicle-card img {
            width: 48px;
            height: 48px;
            flex: 0 0 auto;
            border-radius: 8px;
            object-fit: cover;
            background: #334155;
        }

        .vehicle-main {
            min-width: 0;
            flex: 1;
        }

        .vehicle-main h3 {
            margin: 0 0 4px;
            color: #F8FAFC;
            font-size: 14px;
            line-height: 1.2;
            font-weight: 800;
        }

        .vehicle-main p {
            margin: 0;
            color: #94A3B8;
            font-size: 12px;
            line-height: 1.25;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .status {
            flex: 0 0 auto;
            border-radius: 999px;
            padding: 4px 12px;
            font-size: 10px;
            line-height: 1.2;
            font-weight: 900;
            letter-spacing: 0.05em;
        }

        .ready {
            background: #064E3B;
            color: #34D399;
        }

        .in-service {
            background: #78350F;
            color: #FCD34D;
        }

        .delayed {
            background: #7F1D1D;
            color: #FCA5A5;
        }

        .bottom-nav {
            height: 64px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            align-items: center;
            background: #0F172A;
            border-top: 1px solid #334155;
            padding: 0 10px;
        }

        .tab {
            height: 52px;
            width: 100%;
            border: 0;
            background: transparent;
            color: #64748B;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            font-size: 10px;
            font-weight: 700;
        }

        .tab .tab-inner {
            min-width: 72px;
            padding: 8px 16px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 2px;
        }

        .tab.active {
            color: #2563EB;
        }

        .tab.active .tab-inner {
            background: #1E3A8A;
        }

        .tab svg {
            width: 24px;
            height: 24px;
        }
    </style>
</head>
<body>
    <main class="app-container" aria-label="sdsAUTO fleet dashboard">
        <div class="screen">
            <header class="header">
                <button class="hamburger-btn" type="button" aria-label="Meniu">
                    <svg class="hamburger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                        <path d="M4 7h16M4 12h16M4 17h16" />
                    </svg>
                </button>
                <div class="logo">sdsAUTO</div>
                <button class="bell-btn bell-wrap" type="button" aria-label="Notificări">
                    <svg class="bell" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="bell-dot"></span>
                </button>
                <div class="avatar" aria-label="@userName">AC</div>
            </header>

            <section class="welcome">
                <h1>Salutare, @firstName</h1>
                <p>Performanța flotei tale este optimă astăzi.</p>
            </section>

            <section class="content">
                <article class="fleet-health">
                    <p class="section-label">SĂNĂTATE FLOTĂ</p>
                    <svg class="chart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 3v18h18" />
                        <path d="m7 15 4-4 3 3 5-7" />
                    </svg>
                    <div class="health-row">
                        <div class="health-value">98%</div>
                        <div class="health-delta">+2.4%</div>
                    </div>
                    <div class="progress" aria-label="Sănătate flotă 98%">
                        <span></span>
                    </div>
                </article>

                <div class="stats-grid">
                    <article class="stat-card">
                        <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 5h6" />
                            <path d="M9 3h6a2 2 0 0 1 2 2v1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h1V5a2 2 0 0 1 2-2Z" />
                            <path d="M8 12h8M8 16h5" />
                        </svg>
                        <div class="stat-value">12</div>
                        <div class="stat-label">SARCINI ACTIVE</div>
                    </article>
                    <article class="stat-card">
                        <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.4 2.4-2.8-2.8 2.2-2.6Z" />
                        </svg>
                        <div class="stat-value">3</div>
                        <div class="stat-label">ÎN SERVICE</div>
                    </article>
                </div>

                <section class="live-map">
                    <div class="section-head">
                        <h2 class="section-title">Urmărire Live</h2>
                        <div class="fleet-badge">42 VEHICULE</div>
                    </div>
                    <div class="map-box" role="img" aria-label="Hartă live flotă">
                        <div class="map-road road-a"></div>
                        <div class="map-road road-b"></div>
                        <div class="map-road road-c"></div>
                        <div class="map-road road-d"></div>
                        <div class="location"></div>
                    </div>
                </section>

                <h2 class="recent-title">Flota Recentă</h2>
                <section class="fleet-list" aria-label="Flota recentă">
                    <article class="vehicle-card">
                        <img src="/images/vehicle-tesla.png" alt="Tesla Model S" />
                        <div class="vehicle-main">
                            <h3>B 101 SDS</h3>
                            <p>Tesla Model S • 84% Baterie</p>
                        </div>
                        <span class="status ready">READY</span>
                    </article>

                    <article class="vehicle-card">
                        <img src="/images/vehicle-bmw.png" alt="BMW i7" />
                        <div class="vehicle-main">
                            <h3>B 202 SDS</h3>
                            <p>BMW i7 • Verificare Frâne</p>
                        </div>
                        <span class="status in-service">IN-SERVICE</span>
                    </article>

                    <article class="vehicle-card">
                        <img src="/images/vehicle-audi.png" alt="Porsche Taycan" />
                        <div class="vehicle-main">
                            <h3>B 303 SDS</h3>
                            <p>Porsche Taycan • Eroare Sistem</p>
                        </div>
                        <span class="status delayed">DELAYED</span>
                    </article>
                </section>
            </section>

            <nav class="bottom-nav" aria-label="Navigare principală">
                <button class="tab active" type="button">
                    <span class="tab-inner">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 17h14l-1.5-5.5A3 3 0 0 0 14.6 9H9.4a3 3 0 0 0-2.9 2.5L5 17Z" />
                            <path d="M7 17v2M17 17v2M7.5 13h.01M16.5 13h.01" />
                        </svg>
                        <span>Fleet</span>
                    </span>
                </button>
                <button class="tab" type="button">
                    <span class="tab-inner">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 5h6M9 3h6a2 2 0 0 1 2 2v1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h1V5a2 2 0 0 1 2-2Z" />
                            <path d="m9 14 2 2 4-5" />
                        </svg>
                        <span>Tasks</span>
                    </span>
                </button>
                <button class="tab" type="button">
                    <span class="tab-inner">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19V5M4 19h16" />
                            <path d="M8 16V9M12 16V7M16 16v-4" />
                        </svg>
                        <span>Analytics</span>
                    </span>
                </button>
                <button class="tab" type="button">
                    <span class="tab-inner">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 15.5A3.5 3.5 0 1 0 12 8a3.5 3.5 0 0 0 0 7.5Z" />
                            <path d="M19.4 15a1.8 1.8 0 0 0 .36 1.98l.05.05a2.1 2.1 0 0 1-2.97 2.97l-.05-.05a1.8 1.8 0 0 0-1.98-.36 1.8 1.8 0 0 0-1.1 1.66V21a2.1 2.1 0 0 1-4.2 0v-.08a1.8 1.8 0 0 0-1.1-1.66 1.8 1.8 0 0 0-1.98.36l-.05.05a2.1 2.1 0 0 1-2.97-2.97l.05-.05A1.8 1.8 0 0 0 4.6 15a1.8 1.8 0 0 0-1.66-1.1H3a2.1 2.1 0 0 1 0-4.2h.08A1.8 1.8 0 0 0 4.74 8a1.8 1.8 0 0 0-.36-1.98l-.05-.05A2.1 2.1 0 0 1 7.3 3l.05.05a1.8 1.8 0 0 0 1.98.36A1.8 1.8 0 0 0 10.43 2H10.5a2.1 2.1 0 0 1 4.2 0v.08a1.8 1.8 0 0 0 1.1 1.66 1.8 1.8 0 0 0 1.98-.36l.05-.05A2.1 2.1 0 0 1 20.8 6.3l-.05.05A1.8 1.8 0 0 0 20.4 8c.2.73.86 1.23 1.6 1.23H22a2.1 2.1 0 0 1 0 4.2h-.08A1.8 1.8 0 0 0 19.4 15Z" />
                        </svg>
                        <span>Settings</span>
                    </span>
                </button>
            </nav>
        </div>
    </main>
</body>
</html>
