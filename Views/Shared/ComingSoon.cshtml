@{
    var feature = ViewData["Feature"]?.ToString() ?? "Modul";
    var featureLower = feature.ToLowerInvariant();
}

<div class="page-header">
    <h1 class="page-title">@feature</h1>
    <p class="page-subtitle">Modulul este în curs de dezvoltare și va fi disponibil curând.</p>
</div>

<div class="card-section" style="text-align: center; padding: 5rem 2rem;">
    <div style="background: var(--primary-soft); color: var(--primary); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem;">
        <i data-lucide="construction" style="width: 40px; height: 40px;"></i>
    </div>
    <h2 class="section-title" style="font-size: 1.5rem; margin-bottom: 1rem;">Pagina "@feature" este în lucru</h2>
    <p style="color: var(--text-muted); max-width: 500px; margin: 0 auto 2.5rem;">
        Echipa noastră lucrează la implementarea acestui modul. Aici veți putea gestiona toate aspectele legate de @featureLower în viitorul apropiat.
    </p>
    <a href="/" class="btn btn-primary">
        <i data-lucide="arrow-left" style="width:18px"></i>
        Înapoi la Dashboard
    </a>
</div>
