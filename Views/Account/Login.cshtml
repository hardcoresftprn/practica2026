@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Autentificare - AutoService Manager</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="login-page">
    <div class="login-card">
        <div class="login-header">
            <div class="brand">
                <i data-lucide="wrench" style="width: 32px; height: 32px;"></i>
                <span>AutoService</span>
            </div>
            <h2>Bine ai revenit!</h2>
            <p>Introdu datele de acces pentru a continua</p>
        </div>

        <form method="post" action="/Account/Login">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" style="color:var(--accent); font-weight:600; margin-bottom:1rem; font-size: 0.875rem;"></div>
            
            <div class="form-group">
                <label>Email</label>
                <div style="position: relative;">
                    <i data-lucide="mail" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 18px; color: var(--text-muted);"></i>
                    <input type="email" name="email" value="testare@gmail.com" style="padding-left: 3rem;" placeholder="nume@exemplu.com">
                </div>
            </div>

            <div class="form-group">
                <label>Parolă</label>
                <div style="position: relative;">
                    <i data-lucide="lock" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 18px; color: var(--text-muted);"></i>
                    <input type="password" name="password" value="password" style="padding-left: 3rem;" placeholder="••••••••">
                </div>
            </div>

            <div style="display: flex; justify-content: flex-end; margin-bottom: 1.5rem;">
                <a href="#" style="color: var(--primary); text-decoration: none; font-size: 0.875rem; font-weight: 600;">Ai uitat parola?</a>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; height: 48px; font-size: 1rem;">
                Conectare
            </button>
        </form>

        <div style="margin: 2rem 0; position: relative; text-align: center;">
            <hr style="border: none; border-top: 1px solid #f3f4f6;">
            <span style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 0 1rem; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">sau</span>
        </div>

        <button type="button" class="btn" style="width: 100%; justify-content: center; height: 48px; background: white; border-color: #e5e7eb; color: var(--text-dark);">
            <img src="https://www.google.com/favicon.ico" style="width: 16px; margin-right: 8px;">
            Conectare cu Google
        </button>

        <div class="login-footer">
            <p>© 2025 AutoService Manager. <br>Toate drepturile rezervate.</p>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>

