@model IEnumerable<AutoServiceManager.Models.Client>

@{
    ViewData["Title"] = "Clienți";
    var isAdministrator = string.Equals(Context.Session.GetString("UserRole"), "ADMINISTRATOR", StringComparison.OrdinalIgnoreCase);
}

<div class="page-header">
    <div style="display:flex; justify-content:space-between; align-items:center; width:100%">
        <div>
            <h1 class="page-title">Clienți</h1>
            <p class="page-subtitle">Gestionarea bazei de date a clienților service-ului</p>
        </div>
        @if (isAdministrator)
        {
            <button class="btn btn-primary" type="button" onclick="openCreateModal()">
                <i data-lucide="plus" style="width:18px"></i>
                Adaugă Client
            </button>
        }
        else
        {
            <span class="btn" style="background:#f3f4f6; color:var(--text-muted); cursor:default">
                <i data-lucide="eye" style="width:18px"></i>
                Doar vizualizare
            </span>
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(ViewBag.DatabaseWarning))
{
    <div class="card-section" style="background:#fefce8; border:1px solid #fef08a; padding:1rem; margin-bottom:1.5rem">
        <div style="display:flex; gap:0.75rem; color:#854d0e; font-size:0.875rem; font-weight:500">
            <i data-lucide="alert-triangle" style="width:18px"></i>
            @ViewBag.DatabaseWarning
        </div>
    </div>
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="card-section" style="background:#f0fdf4; border:1px solid #bbf7d0; padding:1rem; margin-bottom:1.5rem">
        <div style="display:flex; gap:0.75rem; color:#166534; font-size:0.875rem; font-weight:500">
            <i data-lucide="check-circle" style="width:18px"></i>
            @successMessage
        </div>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="card-section" style="background:#fef2f2; border:1px solid #fecaca; padding:1rem; margin-bottom:1.5rem">
        <div style="display:flex; gap:0.75rem; color:#991b1b; font-size:0.875rem; font-weight:500">
            <i data-lucide="circle-alert" style="width:18px"></i>
            @errorMessage
        </div>
    </div>
}

<div class="card-section">
    <div class="section-header">
        <div class="search-box">
            <i data-lucide="search" style="width:18px; color:var(--text-muted)"></i>
            <input type="text" placeholder="Caută după nume, telefon, email...">
        </div>
    </div>

    <div style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>Nume</th>
                    <th>Contact</th>
                    <th>Nr. Vehicule</th>
                    <th>Activitate</th>
                    @if (isAdministrator)
                    {
                        <th style="text-align:right">Acțiuni</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div style="font-weight:600; color:var(--text-dark)">@item.FullName</div>
                            <div style="font-size:0.75rem; color:var(--text-muted)">IDNP: @(string.IsNullOrEmpty(item.Idnp) ? "-" : item.Idnp)</div>
                        </td>
                        <td>
                            <div style="display:flex; flex-direction:column; gap:2px">
                                <span style="display:flex; align-items:center; gap:5px"><i data-lucide="phone" style="width:12px; color:var(--text-muted)"></i> @item.Phone</span>
                                <span style="display:flex; align-items:center; gap:5px; font-size:0.8125rem; color:var(--text-muted)"><i data-lucide="mail" style="width:12px"></i> @item.Email</span>
                            </div>
                        </td>
                        <td>
                            <span class="btn" style="background:var(--bg-light); cursor:default; padding: 4px 10px; font-size: 0.75rem;">
                                <i data-lucide="car" style="width:14px"></i> 0
                            </span>
                        </td>
                        <td>
                            <span style="font-size:0.8125rem; color:var(--text-muted)">Fără comenzi active</span>
                        </td>
                        @if (isAdministrator)
                        {
                            <td style="text-align:right">
                                <div style="display:flex; justify-content:flex-end; gap:0.5rem">
                                    <button class="btn edit-client" style="background:#f3f4f6; color:var(--text-dark); padding:0.5rem" type="button"
                                            data-id="@item.ClientId"
                                            data-name="@item.FullName"
                                            data-phone="@item.Phone"
                                            data-email="@item.Email"
                                            data-address="@item.Address"
                                            data-idnp="@item.Idnp">
                                        <i data-lucide="edit-2" style="width:16px"></i>
                                    </button>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Sigur doriți să ștergeți acest client?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.ClientId" />
                                        <button class="btn" style="background:#fef2f2; color:#ef4444; padding:0.5rem" type="submit">
                                            <i data-lucide="trash-2" style="width:16px"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (isAdministrator)
{
    <!-- Create Modal -->
    <div id="createModal" class="modal-overlay" style="display:none">
        <div class="modal-content">
            <div class="section-header">
                <h2 class="section-title">Adaugă Client Nou</h2>
                <button type="button" onclick="closeModal('createModal')" class="btn" style="background:none; color:var(--text-muted)"><i data-lucide="x"></i></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label>Nume Complet *</label>
                    <input type="text" name="FullName" required maxlength="120" placeholder="Ex: Popescu Ion">
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:1rem">
                    <div class="form-group">
                        <label>Telefon *</label>
                        <input type="text" name="Phone" required maxlength="20" placeholder="07xx xxx xxx">
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="Email" maxlength="120" placeholder="ion@exemplu.ro">
                    </div>
                </div>
                <div class="form-group">
                    <label>Adresă</label>
                    <input type="text" name="Address" maxlength="255" placeholder="Strada, Nr, Oraș">
                </div>
                <div class="form-group">
                    <label>CNP / IDNP</label>
                    <input type="text" name="Idnp" maxlength="20" placeholder="Cod numeric personal">
                </div>
                <div style="display:flex; justify-content:flex-end; gap:0.75rem; margin-top:2rem">
                    <button type="button" class="btn" style="background:#f3f4f6" onclick="closeModal('createModal')">Anulează</button>
                    <button type="submit" class="btn btn-primary">Salvează Client</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="editModal" class="modal-overlay" style="display:none">
        <div class="modal-content">
            <div class="section-header">
                <h2 class="section-title">Editează Client</h2>
                <button type="button" onclick="closeModal('editModal')" class="btn" style="background:none; color:var(--text-muted)"><i data-lucide="x"></i></button>
            </div>
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editClientId" name="ClientId">
                <div class="form-group">
                    <label>Nume Complet *</label>
                    <input type="text" id="editName" name="FullName" required maxlength="120">
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:1rem">
                    <div class="form-group">
                        <label>Telefon *</label>
                        <input type="text" id="editPhone" name="Phone" required maxlength="20">
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="editEmail" name="Email" maxlength="120">
                    </div>
                </div>
                <div class="form-group">
                    <label>Adresă</label>
                    <input type="text" id="editAddress" name="Address" maxlength="255">
                </div>
                <div class="form-group">
                    <label>CNP / IDNP</label>
                    <input type="text" id="editIdnp" name="Idnp" maxlength="20">
                </div>
                <div style="display:flex; justify-content:flex-end; gap:0.75rem; margin-top:2rem">
                    <button type="button" class="btn" style="background:#f3f4f6" onclick="closeModal('editModal')">Anulează</button>
                    <button type="submit" class="btn btn-primary">Actualizează</button>
                </div>
            </form>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(17, 24, 39, 0.6);
        backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        z-index: 2000;
        padding: 1rem;
    }
    .modal-content {
        background: white;
        padding: 2rem;
        border-radius: 8px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
</style>

@section Scripts {
    @if (isAdministrator)
    {
        <script>
            document.querySelectorAll('.edit-client').forEach((button) => {
                button.addEventListener('click', () => openEditModal(button.dataset));
            });

            function openCreateModal() {
                document.getElementById('createModal').style.display = 'flex';
                if (window.lucide) {
                    lucide.createIcons();
                }
            }

            function openEditModal(client) {
                document.getElementById('editClientId').value = client.id;
                document.getElementById('editName').value = client.name || '';
                document.getElementById('editPhone').value = client.phone || '';
                document.getElementById('editEmail').value = client.email || '';
                document.getElementById('editAddress').value = client.address || '';
                document.getElementById('editIdnp').value = client.idnp || '';
                document.getElementById('editModal').style.display = 'flex';
                if (window.lucide) {
                    lucide.createIcons();
                }
            }

            function closeModal(id) {
                document.getElementById(id).style.display = 'none';
            }
        </script>
    }
}
